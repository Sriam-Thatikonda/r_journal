<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#1A1A1A">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Active Challenges"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:paddingBottom="12dp" />

    <!-- Challenge 1 -->
    <LinearLayout
        android:id="@+id/challenge_1_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="12dp"
        android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/challenge_1_title" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/challenge_1_progress_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#B3B3B3" />
        </LinearLayout>
        <ProgressBar android:id="@+id/challenge_1_progress_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="4dp" android:max="100" android:progress="0" android:progressTint="#4CAF50"/>
    </LinearLayout>

    <!-- Challenge 2 -->
    <LinearLayout
        android:id="@+id/challenge_2_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="12dp"
        android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/challenge_2_title" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/challenge_2_progress_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#B3B3B3" />
        </LinearLayout>
        <ProgressBar android:id="@+id/challenge_2_progress_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="4dp" android:max="100" android:progress="0" android:progressTint="#4CAF50"/>
    </LinearLayout>

    <!-- Challenge 3 -->
    <LinearLayout
        android:id="@+id/challenge_3_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/challenge_3_title" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="14sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/challenge_3_progress_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#B3B3B3" />
        </LinearLayout>
        <ProgressBar android:id="@+id/challenge_3_progress_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="4dp" android:max="100" android:progress="0" android:progressTint="#4CAF50"/>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No active challenges.\nOpen app to add."
        android:textSize="13sp"
        android:textColor="#9E9E9E"
        android:padding="16dp"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
